// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// Generator
generator client {
  provider = "prisma-client-js"
}

// Datasource
datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

enum user_role {
  user
  admin
}

enum user_status {
  active
  inactive
}

enum material_type {
  plastic
  paper
  metal
  glass
  ewaste
  other
}

enum points_txn_type {
  earn
  redeem
  adjust
  refund
}

enum reward_status {
  active
  inactive
}

enum otp_purpose {
  signup
  reset
}

enum notification_type {
  bin_alert
  session_claimed
  reward_redeemed
  system
}

enum device_type {
  esp32
  other
}

model User {
  id                    Int                 @id @default(autoincrement())
  name                  String?             @db.VarChar(100)
  email                 String              @db.VarChar(100)
  password_hash         String              @db.VarChar(255)
  role                  user_role           @default(user)
  status                user_status         @default(active)
  must_reset_password   Boolean             @default(false)
  password_reset_at     DateTime?

  invited_at            DateTime?
  invited_by            Int?

  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt
  deleted_at            DateTime?

  invited_by_user       User?               @relation("UserInvites", fields: [invited_by], references: [id])
  invited_admins        User[]              @relation("UserInvites")

  sessions              RecyclingSession[]
  reward_redemptions    RewardRedemption[]
  points_transactions   PointsTransaction[]
  devices               UserDevice[]
  notifications         Notification[]

  @@index([deleted_at])
  @@index([email, deleted_at])
  @@index([invited_by])
  @@map("users")
}

model RecyclingSession {
  id           Int             @id @default(autoincrement())
  user_id      Int?
  bin_id       Int?
  total_co2 Decimal @db.Decimal(10, 2) @default("0.00")
  start_weight Decimal? @db.Decimal(8, 2)
  final_weight Decimal? @db.Decimal(8, 2)

  started_at   DateTime @default(now())
  ended_at     DateTime?
  claimed_at   DateTime?

  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt

  user         User?            @relation(fields: [user_id], references: [id])
  bin          Bin?             @relation(fields: [bin_id], references: [id], onDelete: SetNull)
  items        RecyclingItem[]
  points_transactions PointsTransaction[]

  @@index([user_id])
  @@index([bin_id])
  @@map("recycling_sessions")
}

model RecyclingItem {
  id         Int              @id @default(autoincrement())
  session_id Int
  bin_id     Int

  material   material_type
  weight     Decimal          @db.Decimal(8, 2)
  co2_saved  Decimal          @db.Decimal(8, 2)

  created_at DateTime         @default(now())

  session    RecyclingSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  bin        Bin              @relation(fields: [bin_id], references: [id], onDelete: Restrict)

  @@index([session_id])
  @@index([bin_id])
  @@map("recycling_items")
}

model Merchant {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(120)
  email      String   @unique @db.VarChar(120)
  phone      String?  @db.VarChar(30)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?

  rewards     Reward[]

  @@map("merchants")
}

model Reward {
  id              Int           @id @default(autoincrement())
  merchant_id     Int
  name            String        @db.VarChar(150)
  description     String?       @db.Text
  points_needed   Int
  max_redemptions Int?
  max_per_user    Int?

  starts_at       DateTime?
  expires_at      DateTime?

  status          reward_status @default(active)

  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  deleted_at      DateTime?

  merchant        Merchant      @relation(fields: [merchant_id], references: [id])
  redemptions     RewardRedemption[]

  @@index([merchant_id])
  @@index([status, expires_at])
  @@map("rewards")
}

model RewardRedemption {
  id           Int               @id @default(autoincrement())
  reward_id    Int
  user_id      Int

  promo_code   String            @unique @db.VarChar(50)

  redeemed_at  DateTime          @default(now())
  used_at      DateTime?         // when merchant marked as used

  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  reward       Reward            @relation(fields: [reward_id], references: [id])
  user         User              @relation(fields: [user_id], references: [id])

  points_transactions PointsTransaction[]

  @@map("reward_redemptions")
}

model PointsTransaction {
  id             Int            @id @default(autoincrement())
  user_id        Int
  points         Int
  type           points_txn_type

  session_id     Int?
  redemption_id  Int?

  created_at     DateTime       @default(now())

  user           User           @relation(fields: [user_id], references: [id])
  session        RecyclingSession? @relation(fields: [session_id], references: [id], onDelete: SetNull)
  redemption     RewardRedemption? @relation(fields: [redemption_id], references: [id], onDelete: SetNull)

  @@index([user_id, created_at])
  @@index([session_id])
  @@index([redemption_id])
  @@map("points_transactions")
}

model Bin {
  id              Int        @id @default(autoincrement())
  name            String?    @db.VarChar(120)
  material        material_type
  max_weight      Decimal?   @db.Decimal(8, 2)
  current_weight  Decimal    @db.Decimal(8, 2) @default("0.00")
  status          String     @db.VarChar(30) @default("unknown")
  last_seen_at    DateTime?
  half_alert_active Boolean  @default(false)
  full_alert_active Boolean  @default(false)
  location        String?    @db.VarChar(150)
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at      DateTime?

  items    RecyclingItem[]
  logs     BinLog[]
  sessions RecyclingSession[]
  device_maps       BinDeviceMap[]

  @@index([deleted_at])
  @@index([status])
  @@index([material])
  @@map("bins")
}

model BinLog {
  id         Int      @id @default(autoincrement())
  bin_id     Int
  weight     Decimal  @db.Decimal(8, 2)
  created_at DateTime @default(now())

  bin        Bin      @relation(fields: [bin_id], references: [id], onDelete: Cascade)

  @@index([bin_id])
  @@index([created_at])
  @@map("bin_logs")
}

model OtpCode {
  id         Int         @id @default(autoincrement())
  email      String      @db.VarChar(100)
  purpose    otp_purpose
  otp_hash   String      @db.VarChar(255)
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime    @default(now())

  @@index([email, purpose])
  @@index([expires_at])
  @@map("otp_codes")

}

model UserDevice {
  id         Int      @id @default(autoincrement())
  user_id    Int
  fcm_token  String   @db.Text
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("user_devices")
}

model Notification {
  id           Int               @id @default(autoincrement())
  user_id       Int
  title         String           @db.VarChar(150)
  message       String           @db.VarChar(255)
  type          notification_type
  reference_id  Int?
  read_at       DateTime?
  created_at    DateTime         @default(now())

  user          User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, read_at])
  @@index([created_at])
  @@map("notifications")
}

model Device {
  id            Int         @id @default(autoincrement())
  name          String?     @db.VarChar(120)
  type          device_type @default(esp32)
  mac_address   String      @db.VarChar(30)

  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  deleted_at    DateTime?

  bin_maps      BinDeviceMap[]

  @@index([deleted_at])
  @@index([mac_address, deleted_at])
  @@map("devices")
}

model BinDeviceMap {
  id          Int       @id @default(autoincrement())
  bin_id      Int
  device_id   Int

  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  bin         Bin       @relation(fields: [bin_id], references: [id], onDelete: Cascade)
  device      Device    @relation(fields: [device_id], references: [id], onDelete: Cascade)

  @@index([bin_id])
  @@index([device_id])
  @@index([deleted_at])
  @@map("bin_device_maps")
}
